# ── Database ──────────────────────────────────────────────
POSTGRES_USER=netsanctum
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=netsanctum
DATABASE_URL=postgresql+asyncpg://netsanctum:change_me_in_production@postgres:5432/netsanctum
DATABASE_URL_SYNC=postgresql+psycopg2://netsanctum:change_me_in_production@postgres:5432/netsanctum

# ── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Web Server ────────────────────────────────────────────
HOST_PORT=8000
# ── API Key (for external integrations) ──────────────────
MASTER_API_KEY=dev-api-key-change-me
# Symmetric key for file encryption/decryption (AES-256-GCM)
FILE_ENCRYPTION_KEY=dev-file-encryption-key-change-me

# ── Storage ───────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./storage

# S3 (uncomment for production)
# STORAGE_BACKEND=s3
# S3_BUCKET_NAME=my-bucket
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=
